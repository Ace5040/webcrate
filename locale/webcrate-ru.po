msgstr "Остановка: %s"

#: bin/commands/stop.inc:12
msgid "%s stopped and removed"
msgstr "%s остановлен и удалён"

#: bin/commands/stop.inc:19
msgid "Stopping and removing webcrate containers"
msgstr "Остановка и удаление контейнеров webcrate"

#: bin/commands/stop.inc:25
msgid "Removing networks"
msgstr "Удаление сетей"

#: bin/commands/stop.inc:30
msgid "Stopped and removed"
msgstr "Остановлено и удалено"

