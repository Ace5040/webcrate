{% extends 'base.html.twig' %}

{% block title %}Webcrate - project edit{% endblock %}
{% block javascripts %}
    <script type="module" src="{{ asset('build/header.js') }}"></script>
    <script type="module" src="{{ asset('build/admin-project.js') }}"></script>
{% endblock %}

{% block body %}
    <script>
        var user = '{{ app.user ? app.user.email : '' }}';
        window.__modulesData__ = {{ modules_data|default('[]')|raw }};
    </script>
    <div id="header"></div>
    <div class="project-edit-page">
        {{ form_start(form) }}

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.general'|trans }}</h3>
            {% if not is_new|default(false) %}
                {{ form_row(form.uid) }}
            {% else %}
                {% do form.uid.setRendered %}
            {% endif %}
            {{ form_row(form.name) }}
            {{ form_row(form.active) }}
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.domains'|trans }}</h3>
            {{ form_row(form.domains) }}
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.webServer'|trans }}</h3>
            {{ form_row(form.https) }}
            {{ form_row(form.redirect) }}
            {{ form_row(form.nginx_template) }}
            {{ form_row(form.gunicorn_app_module) }}
            {{ form_row(form.gzip) }}
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.nginxConfig'|trans }}</h3>
            {{ form_row(form.nginx_options) }}
            {{ form_row(form.nginx_block) }}
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.access'|trans }}</h3>
            {{ form_row(form.password) }}
            {{ form_row(form.auth_locations) }}
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.storage'|trans }}</h3>
            {{ form_row(form.volume) }}
            {{ form_row(form.root_folder) }}
        </div>

        {# ── Modules section — replaces individual backend/databases/services rows ── #}
        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.modules'|trans }}</h3>
            {# Hidden fields to keep entity in sync (values are overridden by modules_json on submit) #}
            {{ form_row(form.backend) }}
            {{ form_row(form.mysql) }}
            {{ form_row(form.mysql5) }}
            {{ form_row(form.postgre) }}
            {{ form_row(form.Memcached) }}
            {{ form_row(form.Solr) }}
            {{ form_row(form.Elastic) }}
            {# The Vue modules editor mounts here and manages the hidden modules_json field #}
            <div id="app"></div>
            <input type="hidden" id="modules_json_input" name="modules_json" value="">
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.backup'|trans }}</h3>
            {{ form_row(form.backup) }}
            {{ form_row(form.DuplicityFilters) }}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> {{ 'form.save'|trans }}
            </button>
            <a href="{{ path('admin-projects') }}" class="btn btn-outline-secondary">{{ 'form.cancel'|trans }}</a>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
