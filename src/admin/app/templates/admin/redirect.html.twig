{% extends 'base.html.twig' %}

{% block title %}Webcrate - redirect edit{% endblock %}
{% block javascripts %}
    <script type="module" src="{{ asset('build/header.js') }}"></script>
    <script type="module" src="{{ asset('build/admin-redirect.js') }}"></script>
{% endblock %}

{% block body %}
    <script>
        var user = '{{ app.user ? app.user.email : '' }}';
    </script>
    <div id="header"></div>
    <div id="app"></div>
    <div class="redirect-edit-page">
        {{ form_start(form) }}

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.general'|trans }}</h3>
            {{ form_row(form.name) }}
            {{ form_row(form.active) }}
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.domains'|trans }}</h3>
            {{ form_row(form.domains) }}
        </div>

        <div class="form-section">
            <h3 class="form-section-title">{{ 'form.section.redirectSettings'|trans }}</h3>
            {{ form_row(form.url) }}
            {{ form_row(form.https) }}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> {{ 'form.save'|trans }}
            </button>
            <a href="{{ path('admin-redirects') }}" class="btn btn-outline-secondary">{{ 'form.cancel'|trans }}</a>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
